{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "es2022",
        "lib": ["es2022"],
        "types": ["node"],
        "rootDir": ".",
        "outDir": "dist",
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true
    },
    "include": ["bin/**/*.ts", "lib/**/*.ts"]
}
